# BrandForge — environment template. Copy to `.env` and fill in. NEVER commit `.env`.

# --- Backblaze B2 (required) ---
# Create an Application Key at https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=brandforge-media
# Optional region identifier (e.g. us-west-004); leave blank to use the SDK default.
B2_REGION=

# --- Generative provider: GMI Cloud (primary) ---
# Free credits for the first 270 hackathon participants: https://forms.gle/wkGKtUvk8dbqrEwT8
GMICLOUD_API_KEY=

# --- Generative provider: OpenAI (fallback for images) ---
OPENAI_API_KEY=

# --- Captions (Anthropic) ---
ANTHROPIC_API_KEY=

# --- App ---
# Comma-separated public base path or CDN host for delivery URLs (optional).
BRANDFORGE_PUBLIC_BASE_URL=
